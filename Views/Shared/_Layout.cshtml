<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DACS</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DACS.styles.css" asp-append-version="true" />
    <!-- FontAwesome & Leaflet -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">DACS</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Dashboard"><i class="fas fa-chart-line me-1"></i> Thống kê</a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark text-primary fw-bold" asp-area="" asp-controller="User" asp-action="Index"><i class="fas fa-users-cog me-1"></i> Quản lý User</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark text-success fw-bold" asp-area="" asp-controller="ThietBi" asp-action="Index"><i class="fas fa-microchip me-1"></i> Quản lý Thiết bị</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark text-info fw-bold" asp-area="" asp-controller="PhuongTien" asp-action="Index"><i class="fas fa-car me-1"></i> Quản lý Phương tiện</a>
                            </li>
                        }
                        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark text-warning fw-bold" asp-area="" asp-controller="KhachHang" asp-action="Index"><i class="fas fa-users me-1"></i> Quản lý Khách hàng</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark text-secondary fw-bold" asp-area="" asp-controller="HopDong" asp-action="Index"><i class="fas fa-file-contract me-1"></i> Quản lý Hợp đồng</a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="navbarProfile" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <div class="avatar-circle me-2 d-flex align-items-center justify-content-center bg-primary text-white rounded-circle shadow-sm" style="width: 32px; height: 32px;">
                                        <i class="fas fa-user-circle"></i>
                                    </div>
                                    <span class="text-dark fw-bold">@User.FindFirst("FullName")?.Value</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg mt-2 py-2" aria-labelledby="navbarProfile" style="border-radius: 12px; min-width: 200px;">
                                    <li>
                                        <div class="px-3 py-2 border-bottom mb-1">
                                            <p class="small text-muted mb-0">Đang đăng nhập với</p>
                                            <p class="fw-bold mb-0">@User.Identity.Name</p>
                                        </div>
                                    </li>
                                    <li>
                                        <a class="dropdown-item py-2" asp-controller="Account" asp-action="Profile">
                                            <i class="fas fa-user-cog me-2 text-primary"></i> Hồ sơ cá nhân
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item py-2" asp-controller="Account" asp-action="Logout">
                                            <i class="fas fa-sign-out-alt me-2 text-danger"></i> Đăng xuất
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link btn btn-outline-primary btn-sm px-4 rounded-pill shadow-sm" asp-area="" asp-controller="Account" asp-action="Login">
                                    <i class="fas fa-sign-in-alt me-1"></i> Đăng nhập
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <main role="main">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
