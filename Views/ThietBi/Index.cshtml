@model IEnumerable<DACS.Models.ThietBiGPS>

@{
    ViewData["Title"] = "Quản lý thiết bị GPS";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-1"><i class="fas fa-microchip me-2"></i>Quản lý thiết bị GPS</h3>
            <p class="text-muted small mb-0">Danh sách các thiết bị GPS được quản lý trong hệ thống</p>
        </div>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="fas fa-plus-circle me-1"></i> Thêm thiết bị mới
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Mã IMEI</th>
                            <th>Loại thiết bị</th>
                            <th>Ngày kích hoạt</th>
                            <th>Trạng thái</th>
                            <th class="text-end pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="fas fa-box-open d-block mb-3 fs-1 opacity-25"></i>
                                    Chưa có thiết bị nào được đăng ký.
                                </td>
                            </tr>
                        }
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-sm bg-info bg-opacity-10 text-info rounded-3 d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                                            <i class="fas fa-broadcast-tower"></i>
                                        </div>
                                        <div>
                                            <span class="fw-bold d-block">@item.MaImei</span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="text-secondary">@item.LoaiThietBi</span>
                                </td>
                                <td>@item.NgayKichHoat.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (item.TrangThai)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3">
                                            <i class="fas fa-check-circle me-1 small"></i> Đang hoạt động
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-3">
                                            <i class="fas fa-times-circle me-1 small"></i> Ngừng hoạt động
                                        </span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-action="Edit" asp-route-id="@item.IdThietBi" class="btn btn-sm btn-outline-primary border-0 me-1" title="Chỉnh sửa">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <button onclick="deleteDevice(@item.IdThietBi, '@item.MaImei')" class="btn btn-sm btn-outline-danger border-0" title="Xóa">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function deleteDevice(id, imei) {
            Swal.fire({
                title: 'Xác nhận xóa thiết bị?',
                text: "Bạn có chắc chắn muốn xóa thiết bị có mã IMEI '" + imei + "'? Hành động này không thể hoàn tác.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Xóa ngay',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/ThietBi/Delete/' + id,
                        type: 'POST',
                        success: function (res) {
                            if (res.success) {
                                Swal.fire('Đã xóa!', res.message, 'success')
                                    .then(() => location.reload());
                            } else {
                                Swal.fire('Lỗi!', res.message, 'error');
                            }
                        },
                        error: function() {
                            Swal.fire('Lỗi!', 'Đã xảy ra lỗi trong quá trình xử lý.', 'error');
                        }
                    });
                }
            })
        }
    </script>
}
