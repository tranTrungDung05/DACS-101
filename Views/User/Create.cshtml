@model DACS.Models.TaiKhoan

@{
    ViewData["Title"] = "Thêm người dùng mới";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="fw-bold mb-0 text-center text-primary">THÊM NGƯỜI DÙNG MỚI</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold">Họ và tên</label>
                            <input asp-for="HoTen" class="form-control" placeholder="Nhập họ và tên đầy đủ" required />
                            <span asp-validation-for="HoTen" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold">Email</label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="Địa chỉ email" required />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold">Tên đăng nhập</label>
                            <input asp-for="TenDangNhap" class="form-control" placeholder="Tên tài khoản" required />
                            <span asp-validation-for="TenDangNhap" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold">Mật khẩu</label>
                            <input asp-for="MatKhau" type="text" class="form-control" placeholder="Mật khẩu truy cập" required />
                            <span asp-validation-for="MatKhau" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold">Chức vụ</label>
                            <select asp-for="IdChucVu" class="form-select" asp-items="ViewBag.IdChucVu"></select>
                            <span asp-validation-for="IdChucVu" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">LƯU TÀI KHOẢN</button>
                            <a asp-action="Index" class="btn btn-light text-muted">Hủy bỏ</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
