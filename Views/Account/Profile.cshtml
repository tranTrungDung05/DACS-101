@model DACS.Models.TaiKhoan
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">
            <div class="card shadow-sm overflow-hidden" style="border-radius: 15px; border: none;">
                <div class="card-header bg-primary text-white p-3 text-center border-0">
                    <div class="d-inline-flex align-items-center justify-content-center bg-white bg-opacity-25 rounded-circle mb-2" style="width: 50px; height: 50px;">
                        <i class="fas fa-user-circle fa-xl"></i>
                    </div>
                    <h5 class="fw-bold mb-0">Hồ sơ cá nhân</h5>
                </div>
                <div class="card-body p-4">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success py-2 border-0 mb-3 small shadow-sm" style="border-radius: 8px;">
                            <i class="fas fa-check-circle me-1"></i> @TempData["SuccessMessage"]
                        </div>
                    }

                    <form asp-action="UpdateProfile" method="post">
                        <!-- Họ và tên -->
                        <div class="mb-3">
                            <label class="form-label text-muted small fw-bold text-uppercase mb-1">Họ và tên</label>
                            <input type="text" name="hoTen" class="form-control border-light shadow-sm bg-light" value="@Model.HoTen" required style="border-radius: 10px;">
                        </div>
                        
                        <!-- Email -->
                        <div class="mb-3">
                            <label class="form-label text-muted small fw-bold text-uppercase mb-1">Email</label>
                            <input type="email" name="email" class="form-control border-light shadow-sm bg-light" value="@Model.Email" required style="border-radius: 10px;">
                        </div>

                        <!-- Tên đăng nhập -->
                        <div class="mb-3">
                            <label class="form-label text-muted small fw-bold text-uppercase mb-1">Tên đăng nhập</label>
                            <input type="text" class="form-control border-light bg-light text-muted" value="@Model.TenDangNhap" readonly style="border-radius: 10px; cursor: not-allowed; height: 42px;">
                        </div>

                        <!-- Chức vụ -->
                        <div class="mb-4">
                            <label class="form-label text-muted small fw-bold text-uppercase mb-1">Chức vụ</label>
                            <div class="d-flex align-items-center justify-content-start ps-1" style="height: 42px;">
                                <span class="badge bg-info text-dark fw-normal pill px-3">@Model.ChucVu?.TenChucVu</span>
                            </div>
                        </div>

                        <!-- Buttons -->
                        <div class="d-grid gap-2 mb-3">
                            <button type="submit" class="btn btn-primary fw-bold rounded-pill py-2 shadow-sm transition-all hover-lift">
                                <i class="fas fa-save me-2"></i> Lưu thay đổi
                            </button>
                            <a asp-action="ChangePassword" class="btn btn-outline-warning text-dark fw-bold rounded-pill py-2 shadow-sm transition-all hover-lift">
                                <i class="fas fa-key me-2"></i> Đổi mật khẩu
                            </a>
                        </div>
                        
                        <hr class="my-3 opacity-10">
                        
                        <div class="text-center">
                            <a asp-controller="Home" asp-action="Index" class="btn btn-link text-decoration-none text-muted small py-0">
                                <i class="fas fa-arrow-left me-1"></i> Quay lại trang chủ
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-lift { transition: transform 0.2s; }
    .hover-lift:hover { transform: translateY(-1px); }
    .form-control:focus {
        background-color: #fff !important;
        border-color: #0d6efd !important;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15) !important;
    }
</style>
