@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">
            <div class="card border-0 shadow-sm" style="border-radius: 15px;">
                <div class="card-header bg-warning text-dark p-3 text-center" style="border-radius: 15px 15px 0 0;">
                    <div class="d-inline-flex align-items-center justify-content-center bg-dark bg-opacity-10 rounded-circle mb-2" style="width: 60px; height: 60px;">
                        <i class="fas fa-shield-alt fa-2x"></i>
                    </div>
                    <h4 class="fw-bold mb-0">Đổi mật khẩu</h4>
                </div>
                <div class="card-body p-4">
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger py-2 border-0 mb-4 small" style="border-radius: 8px;">
                            <i class="fas fa-exclamation-circle me-1"></i> @TempData["ErrorMessage"]
                        </div>
                    }
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success py-2 border-0 mb-4 small" style="border-radius: 8px;">
                            <i class="fas fa-check-circle me-1"></i> @TempData["SuccessMessage"]
                        </div>
                    }

                    <form asp-action="ChangePassword" method="post">
                        <div class="mb-3">
                            <label for="oldPassword" class="form-label small fw-bold text-muted">Mật khẩu hiện tại</label>
                            <input type="password" class="form-control" id="oldPassword" name="oldPassword" required placeholder="••••••••">
                        </div>
                        <div class="mb-4">
                            <label for="newPassword" class="form-label small fw-bold text-muted">Mật khẩu mới</label>
                            <input type="password" class="form-control" id="newPassword" name="newPassword" required placeholder="Nhập mật khẩu mới">
                        </div>
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary fw-bold rounded-pill shadow-sm">
                                Xác nhận đổi mật khẩu
                            </button>
                            <a asp-action="Profile" class="btn btn-link btn-sm text-decoration-none text-muted">Hủy bỏ</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card { animation: slideUp 0.3s ease-out; }
    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
