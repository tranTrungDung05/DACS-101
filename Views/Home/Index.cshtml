@model IEnumerable<DACS.Models.PhuongTien>

@{
    ViewData["Title"] = "Vehicle Tracking GPS";
}

<style>
    .tracking-wrapper { display: flex; height: calc(100vh - 56px); width: 100%; overflow: hidden; background-color: #f4f6f9; }
    
    .vehicle-sidebar { width: 320px; background: #fff; border-right: 1px solid #dee2e6; display: flex; flex-direction: column; z-index: 1000; box-shadow: 2px 0 5px rgba(0,0,0,.05); }
    .sidebar-header { padding: 15px; background: #343a40; color: #fff; }
    .vehicle-list { overflow-y: auto; flex-grow: 1; }
    .vehicle-item { padding: 12px 15px; border-bottom: 1px solid #f4f4f4; cursor: pointer; transition: 0.2s; position: relative; }
    .vehicle-item:hover { background: #f0f7ff; }
    .vehicle-item.active { background-color: #e2efff; border-left: 4px solid #007bff; }
    
    .status-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; margin-right: 5px; }
    .status-online { background-color: #28a745; }
    .status-offline { background-color: #ffc107; }

    .map-container { flex-grow: 1; position: relative; }
    #trackingMap { width: 100%; height: 100%; }
    .history-control {
        position: absolute; bottom: 25px; left: 50%; transform: translateX(-50%);
        background: rgba(255, 255, 255, 0.98); padding: 15px 20px; border-radius: 10px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.2); z-index: 1000; min-width: 650px;
        display: none; border: 1px solid #ddd;
    }

    .violation-marker {
        background: #dc3545; border: 2px solid #fff; border-radius: 50%;
        box-shadow: 0 0 8px rgba(220, 53, 69, 0.8);
        animation: blink-red 1s infinite;
    }
    @@keyframes blink-red { 0% { opacity: 1; } 50% { opacity: 0.5; } 100% { opacity: 1; } }
</style>

<div class="tracking-wrapper">
    <div class="vehicle-sidebar">
        <div class="sidebar-header">
            <h6 class="mb-2"><i class="fas fa-satellite"></i> Danh sách xe</h6>
            <input type="text" id="txtSearch" onkeyup="filterVehicles()" class="form-control form-control-sm" placeholder="Nhập biển số xe...">
        </div>
        <div class="vehicle-list" id="vehicleList">
            @foreach (var item in Model)
            {
                var latestGPS = item.HanhTrinhs.OrderByDescending(h => h.NgayDi).FirstOrDefault()?.DuLieuGPS.OrderByDescending(d => d.Timestamp).FirstOrDefault();
                var statusClass = item.TrangThai ? "status-online" : "status-offline";
                var speed = latestGPS?.TocDo ?? 0;

                <div class="vehicle-item" id="item-@item.BienSo.Replace("-", "").Replace(".", "")" onclick="selectVehicle('@item.BienSo')">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-bold plate-txt"><i class="status-dot @statusClass"></i> @item.BienSo</span>
                        <span class="badge @(item.TrangThai ? "bg-success" : "bg-warning text-dark")">@(item.TrangThai ? "Sẵn sàng" : "Đang bận")</span>
                    </div>
                    <div class="small text-muted mt-1">Cập nhật: @(latestGPS != null ? latestGPS.Timestamp.ToString("HH:mm") : "N/A")</div>
                    <div class="mt-2">
                        <button class="btn btn-xs btn-primary py-0 px-2" onclick="openHistory('@item.BienSo', event)"><i class="fas fa-route"></i> Lịch sử</button>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="map-container">
        <div id="trackingMap"></div>

        <div class="history-control" id="pnlHistory">
            <div class="d-flex flex-wrap align-items-center justify-content-between">
                <div class="d-flex align-items-center gap-3">
                    <span class="fw-bold fs-6">Biển số: <span id="lblPlate" class="text-primary"></span></span>
                    <div class="btn-group shadow-sm" role="group">
                        <button class="btn btn-sm btn-success px-3" onclick="playback(1)"><i class="fas fa-play"></i> 1x</button>
                        <button class="btn btn-sm btn-outline-success bg-white px-3" onclick="playback(3)">3x</button>
                        <button class="btn btn-sm btn-outline-success bg-white px-3" onclick="playback(8)">8x</button>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <button class="btn btn-sm btn-danger shadow-sm px-3" onclick="stopPlayback()"><i class="fas fa-stop"></i> Dừng</button>
                    <button class="btn btn-sm btn-dark shadow-sm px-3" onclick="closeHistory()"><i class="fas fa-times"></i> Đóng</button>
                </div>
            </div>
            <hr class="my-2 text-muted">
            <div class="small text-muted text-center fw-bold" id="lblProgress">Lộ trình đã sẵn sàng. Nhấn nút Tốc độ để bắt đầu.</div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const db = {
            @foreach (var item in Model)
            {
                var latestHanhTrinh = item.HanhTrinhs.OrderByDescending(h => h.NgayDi).FirstOrDefault();
                var latestGPS = latestHanhTrinh?.DuLieuGPS.OrderByDescending(d => d.Timestamp).FirstOrDefault();
                var waypoints = latestHanhTrinh?.DuLieuGPS.OrderBy(d => d.Timestamp).TakeLast(200).Select(d => $"[{d.ViDo}, {d.KinhDo}, {d.TocDo}]");
                
                if (latestGPS != null) {
                    @: "@item.BienSo": {
                    @:    pos: [@latestGPS.ViDo, @latestGPS.KinhDo],
                    @:    waypoints: [@Html.Raw(string.Join(",", waypoints ?? new List<string>()))],
                    @:    violation: null, 
                    @:    detailedRoute: null
                    @: },
                }
            }
        };

        var map = L.map('trackingMap').setView([10.8015, 106.7111], 15);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
        var carIcon = L.icon({ iconUrl: 'https://cdn-icons-png.flaticon.com/512/3202/3202926.png', iconSize: [32, 32], iconAnchor: [16, 16] });
        
        var markers = {}, pathLine = null, moveMarker = null, flagMarkers = [];
        var playbackTimer = null, currentIdx = 0, currentPlate = "";

        Object.keys(db).forEach(plate => {
            markers[plate] = L.marker(db[plate].pos, { icon: carIcon }).addTo(map).bindPopup(`<b>${plate}</b>`);
        });

        // SIGNALR CONNECTION
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/gpsHub")
            .withAutomaticReconnect()
            .build();

        connection.on("ReceiveLocationUpdate", (plate, lat, lng, speed) => {
            console.log(`Update: ${plate} -> ${lat}, ${lng} (${speed} km/h)`);
            
            if (!markers[plate]) {
                markers[plate] = L.marker([lat, lng], { icon: carIcon }).addTo(map).bindPopup(`<b>${plate}</b>`);
                db[plate] = { pos: [lat, lng], waypoints: [[lat, lng]], detailedRoute: null, violation: null };
            } else {
                markers[plate].setLatLng([lat, lng]);
                db[plate].pos = [lat, lng];
            }

            // Update Sidebar UI
            const item = document.getElementById('item-' + plate.replace(/[-.]/g, ''));
            if (item) {
                const badge = item.querySelector('.badge');
                if (badge) {
                    // Cập nhật màu dấu chấm trạng thái nếu cần, nhưng giữ nguyên nhãn Sẵn sàng/Đang bận
                    const dot = item.querySelector('.status-dot');
                    if (dot) {
                        dot.className = speed > 0 ? "status-dot status-online" : "status-dot status-offline";
                    }
                }
                const updateTime = item.querySelector('.text-muted');
                if (updateTime) updateTime.innerText = "Cập nhật: Vừa xong";
            }
        });

        connection.start().catch(err => console.error(err));

        async function getRoadGeometry(waypoints) {
            let coords = waypoints.map(p => `${p[1]},${p[0]}`).join(';');
            let url = `https://router.project-osrm.org/route/v1/driving/${coords}?overview=full&geometries=geojson`;
            try {
                let res = await fetch(url);
                let data = await res.json();
                if(data.routes && data.routes.length > 0) {
                    return data.routes[0].geometry.coordinates.map(c => [c[1], c[0]]);
                }
            } catch(err) {
                console.error("Lỗi API tìm đường:", err);
            }
            return waypoints;
        }

        function selectVehicle(plate) {
            currentPlate = plate;
            document.querySelectorAll('.vehicle-item').forEach(v => v.classList.remove('active'));
            document.getElementById('item-' + plate.replace(/[-.]/g, '')).classList.add('active');
            if (db[plate]) {
                map.flyTo(db[plate].pos, 16);
                markers[plate].openPopup();
            }
        }

        function filterVehicles() {
            let val = document.getElementById('txtSearch').value.toUpperCase();
            document.querySelectorAll('.vehicle-item').forEach(item => {
                let text = item.querySelector('.plate-txt').innerText.toUpperCase();
                item.style.display = text.includes(val) ? "block" : "none";
            });
        }

        async function openHistory(plate, e) {
            e.stopPropagation();
            selectVehicle(plate);
            resetMapObjects();

            document.getElementById('pnlHistory').style.display = 'block';
            document.getElementById('lblPlate').innerText = plate;
            document.getElementById('lblProgress').innerHTML = '<i class="fas fa-spinner fa-spin text-primary"></i> Đang tải lộ trình thông minh...';

            let carData = db[plate];
            if (!carData) return;
            
            if (!carData.detailedRoute) {
                // Nếu đã có nhiều điểm (giả lập hoặc hành trình thực), dùng luôn các điểm đó làm route
                if (carData.waypoints.length > 50) {
                    carData.detailedRoute = carData.waypoints;
                } else {
                    carData.detailedRoute = await getRoadGeometry(carData.waypoints);
                }
            }

            let drawRoute = carData.detailedRoute;
            document.getElementById('lblProgress').innerText = 'Lộ trình đã sẵn sàng. Nhấn nút Tốc độ để bắt đầu.';

            pathLine = L.polyline(drawRoute, { color: '#0d6efd', weight: 6, opacity: 0.8 }).addTo(map);
            L.marker(drawRoute[0]).addTo(map).bindPopup("<b>Điểm xuất phát</b>");
            L.marker(drawRoute[drawRoute.length - 1]).addTo(map).bindPopup("<b>Điểm dừng cuối</b>");
            
            map.fitBounds(pathLine.getBounds());
            markers[plate].setOpacity(0); 
        }

        function playback(speed) {
            stopPlayback();
            let carData = db[currentPlate];
            let route = carData.detailedRoute;
            if (!route) return;
            let vInfo = carData.violation;

            let violationIndex = vInfo ? Math.floor(route.length * vInfo.triggerPercent) : -1;

            if (!moveMarker) {
                currentIdx = 0;
                moveMarker = L.marker(route[0], { icon: carIcon }).addTo(map);
            }

            playbackTimer = setInterval(() => {
                currentIdx += speed;
                
                if (currentIdx >= route.length - 1) {
                    stopPlayback();
                    Swal.fire({
                        toast: true,
                        position: 'top-end',
                        showConfirmButton: false,
                        timer: 3000,
                        timerProgressBar: true,
                        icon: 'success',
                        title: 'Thông tin hành trình',
                        text: 'Xe đã về đến đích!',
                        iconColor: 'white',
                        customClass: {
                            popup: 'bg-success text-white'
                        }
                    });
                    currentIdx = 0;
                    document.getElementById('lblProgress').innerText = 'Xe đã về đến đích. Đã hoàn thành mô phỏng.';
                    return;
                }

                let p = route[currentIdx];
                moveMarker.setLatLng([p[0], p[1]]);
                
                if (currentIdx % (speed * 2) === 0) map.panTo([p[0], p[1]], {animate: true});
                
                let speedInfo = p[2] !== undefined ? ` | Tốc độ: <span class="text-danger">${p[2].toFixed(1)} km/h</span>` : "";
                document.getElementById('lblProgress').innerHTML = `Tọa độ GPS: ${p[0].toFixed(5)} , ${p[1].toFixed(5)}${speedInfo}`;

                if (vInfo && currentIdx >= violationIndex && currentIdx < violationIndex + speed) {
                    let flag = L.marker(p, { 
                        icon: L.divIcon({ className: 'violation-marker', iconSize: [16, 16] }) 
                    }).addTo(map).bindPopup(`<h6 class="text-danger mb-1"><i class="fas fa-exclamation-triangle"></i> ${vInfo.type}</h6>${vInfo.detail}`).openPopup();
                    flagMarkers.push(flag);
                }
            }, 200); 
        }

        function stopPlayback() {
            clearInterval(playbackTimer);
        }

        function resetMapObjects() {
            if (pathLine) map.removeLayer(pathLine);
            if (moveMarker) map.removeLayer(moveMarker);
            flagMarkers.forEach(f => map.removeLayer(f));
            flagMarkers = [];
            currentIdx = 0;
            moveMarker = null;
            stopPlayback();
        }

        function closeHistory() {
            document.getElementById('pnlHistory').style.display = 'none';
            resetMapObjects();
            if(markers[currentPlate]) markers[currentPlate].setOpacity(1);
        }
    </script>
}

