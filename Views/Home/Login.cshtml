@{
    // Loại bỏ Layout mặc định (không hiển thị thanh Menu của hệ thống)
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - Hệ thống Tracking GPS</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        body {
            /* Hình nền mờ ảo tạo cảm giác công nghệ / bản đồ */
            background: linear-gradient(135deg, #0d6efd 0%, #0dcaf0 100%);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: Arial, sans-serif;
        }

        .auth-card {
            background: #fff;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            width: 100%;
            max-width: 450px;
            overflow: hidden;
        }

        .auth-header {
            background: #f8f9fa;
            padding: 30px 20px 20px;
            text-align: center;
            border-bottom: 1px solid #eee;
        }

        .auth-header i {
            font-size: 3rem;
            color: #0d6efd;
            margin-bottom: 10px;
        }

        .auth-body {
            padding: 30px;
        }

        /* Tùy chỉnh form input */
        .input-group-text { background: transparent; border-right: none; color: #6c757d; }
        .form-control { border-left: none; }
        .form-control:focus { box-shadow: none; border-color: #ced4da; }
        .input-group:focus-within .input-group-text, .input-group:focus-within .form-control { border-color: #0d6efd; color: #0d6efd; }

        .btn-auth { width: 100%; padding: 10px; font-weight: bold; border-radius: 8px; }

        /* Link liên hệ hỗ trợ */
        .support-text { font-size: 0.85rem; color: #6c757d; text-align: center; }
        .support-text a { color: #0d6efd; text-decoration: none; font-weight: 600; }
    </style>
</head>
<body>

    <div class="auth-card">
        <div class="auth-header">
            <i class="fas fa-map-marked-alt"></i>
            <h4 class="fw-bold mb-0">HỆ THỐNG TRACKING</h4>
            <p class="text-muted small mb-0">Giám sát hành trình GPS</p>
        </div>

        <div class="auth-body">
            
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success py-2 small">
                    <i class="fas fa-check-circle me-1"></i> @TempData["SuccessMessage"]
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger py-2 small">
                    <i class="fas fa-exclamation-circle me-1"></i> @TempData["ErrorMessage"]
                </div>
            }

            <div id="loginForm">
                <h5 class="fw-bold mb-4 text-center">Đăng Nhập Quản Trị</h5>
                <form asp-controller="Account" asp-action="Login" method="post">
                    <div class="mb-3">
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-user"></i></span>
                            <input type="text" name="username" class="form-control" placeholder="Tên đăng nhập" required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-lock"></i></span>
                            <input type="password" name="password" class="form-control" placeholder="Mật khẩu" required>
                        </div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-4 small">
                        <label class="form-check-label"><input type="checkbox" class="form-check-input me-1"> Ghi nhớ tôi</label>
                        <a href="#" class="text-muted">Quên mật khẩu?</a>
                    </div>
                    <button type="submit" class="btn btn-primary btn-auth">ĐĂNG NHẬP</button>
                </form>
                <div class="support-text mt-4">
                    Nếu bạn chưa có tài khoản, vui lòng liên hệ <a href="#">Người quản trị hệ thống</a> để được cấp quyền truy cập.
                </div>
            </div>

        </div>
    </div>

    <!-- Script toggleAuthMode đã bị gỡ bỏ -->
</body>
</html>