@model DACS.Models.PhuongTien

@{
    ViewData["Title"] = "Thêm phương tiện mới";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Danh sách phương tiện</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Thêm mới</li>
                </ol>
            </nav>

            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="fw-bold mb-0 text-primary"><i class="fas fa-plus-circle me-2"></i>ĐĂNG KÝ PHƯƠNG TIỆN MỚI</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-bold text-uppercase">Biển số xe</label>
                                <input asp-for="BienSo" class="form-control" placeholder="Ví dụ: 29A-123.45" required />
                                <span asp-validation-for="BienSo" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-bold text-uppercase">Loại xe</label>
                                <select asp-for="LoaiPhuongTien" class="form-select">
                                    <option value="Xe 4 chỗ">Xe 4 chỗ</option>
                                    <option value="Xe 7 chỗ">Xe 7 chỗ</option>
                                    <option value="Xe tải">Xe tải</option>
                                    <option value="Xe khách">Xe khách</option>
                                </select>
                                <span asp-validation-for="LoaiPhuongTien" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-bold text-uppercase">Hãng sản xuất</label>
                                <input asp-for="HangSanXuat" class="form-control" placeholder="Ví dụ: Toyota, Honda..." required />
                                <span asp-validation-for="HangSanXuat" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-bold text-uppercase">Màu sắc</label>
                                <input asp-for="MauSac" class="form-control" placeholder="Nhập màu của xe" required />
                                <span asp-validation-for="MauSac" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-uppercase">Gắn thiết bị GPS</label>
                            <select asp-for="IdThietBi" class="form-select shadow-sm" asp-items="ViewBag.IdThietBi">
                                <option value="">-- Chọn thiết bị GPS --</option>
                            </select>
                            <span asp-validation-for="IdThietBi" class="text-danger small"></span>
                            <div class="form-text small">Mỗi xe cần được gắn một thiết bị GPS để theo dõi hành trình.</div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold text-uppercase">Trạng thái ban đầu</label>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="TrangThai" checked>
                                <label class="form-check-label small" for="TrangThai">Phương tiện sẵn sàng hoạt động</label>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg fs-6 fw-bold shadow-sm">
                                <i class="fas fa-save me-1"></i> LƯU PHƯƠNG TIỆN
                            </button>
                            <a asp-action="Index" class="btn btn-light text-muted">Hủy bỏ và quay lại</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
