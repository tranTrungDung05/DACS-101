@model IEnumerable<DACS.Models.PhuongTien>

@{
    ViewData["Title"] = "Quản lý Phương tiện";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-1"><i class="fas fa-car me-2"></i>Quản lý Phương tiện</h3>
            <p class="text-muted small mb-0">Danh sách các phương tiện và thiết bị GPS đi kèm</p>
        </div>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="fas fa-plus-circle me-1"></i> Thêm phương tiện mới
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Biển số xe</th>
                            <th>Loại xe</th>
                            <th>Hãng/Màu sắc</th>
                            <th>Thiết bị GPS</th>
                            <th>Trạng thái</th>
                            <th class="text-end pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="fas fa-car-side d-block mb-3 fs-1 opacity-25"></i>
                                    Chưa có phương tiện nào được đăng ký.
                                </td>
                            </tr>
                        }
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <span class="badge bg-dark px-3 py-2 fs-6">@item.BienSo</span>
                                </td>
                                <td>
                                    <span class="fw-semibold">@item.LoaiPhuongTien</span>
                                </td>
                                <td>
                                    <div class="small">
                                        <span class="text-muted">Hãng:</span> @item.HangSanXuat <br/>
                                        <span class="text-muted">Màu:</span> @item.MauSac
                                    </div>
                                </td>
                                <td>
                                    @if (item.ThietBiGPS != null)
                                    {
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-xs bg-info bg-opacity-10 text-info rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 30px; height: 30px;">
                                                <i class="fas fa-microchip small"></i>
                                            </div>
                                            <span class="small fw-bold">@item.ThietBiGPS.MaImei</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary opacity-50">Chưa gắn</span>
                                    }
                                </td>
                                <td>
                                    @if (item.TrangThai)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3">
                                            Sẵn sàng
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning rounded-pill px-3">
                                            Đang bận
                                        </span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-action="Edit" asp-route-id="@item.IdPhuongTien" class="btn btn-sm btn-outline-primary border-0 me-1" title="Chỉnh sửa">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <button onclick="deleteVehicle(@item.IdPhuongTien, '@item.BienSo')" class="btn btn-sm btn-outline-danger border-0" title="Xóa">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function deleteVehicle(id, bienSo) {
            Swal.fire({
                title: 'Xác nhận xóa phương tiện?',
                text: "Bạn có chắc chắn muốn xóa phương tiện '" + bienSo + "'? Hành động này không thể hoàn tác.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Xóa ngay',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/PhuongTien/Delete/' + id,
                        type: 'POST',
                        success: function (res) {
                            if (res.success) {
                                Swal.fire('Đã xóa!', res.message, 'success')
                                    .then(() => location.reload());
                            } else {
                                Swal.fire('Lỗi!', res.message, 'error');
                            }
                        },
                        error: function() {
                            Swal.fire('Lỗi!', 'Đã xảy ra lỗi trong quá trình xử lý.', 'error');
                        }
                    });
                }
            })
        }
    </script>
}
