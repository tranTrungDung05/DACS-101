@model DACS.Models.HopDong
@{
    ViewData["Title"] = "Chi tiết Hợp đồng";
}

<div class="container py-4">
    <div class="row">
        <!-- Thông tin chung -->
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="m-0"><i class="fas fa-info-circle me-2"></i>Thông tin chung</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3 border-bottom pb-2">
                        <label class="small text-muted d-block">Mã Hợp đồng</label>
                        <span class="h5 fw-bold text-primary">HĐ-@Model.IdHopDong.ToString("D4")</span>
                    </div>
                    <div class="mb-3 border-bottom pb-2">
                        <label class="small text-muted d-block">Khách hàng</label>
                        <span class="fw-bold">@Model.KhachHang?.HoTen</span>
                        <div class="small">CCCD: @Model.MaCccd</div>
                        <div class="small">SĐT: @Model.KhachHang?.Sdt</div>
                    </div>
                    <div class="mb-3 border-bottom pb-2">
                        <label class="small text-muted d-block">Ngày tạo</label>
                        <span>@Model.NgayTao.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="mb-3 border-bottom pb-2">
                        <label class="small text-muted d-block">Tổng tiền</label>
                        <span class="h5 fw-bold text-danger">@Model.TongTien.ToString("N0") VNĐ</span>
                    </div>
                    <div class="mb-3">
                        <label class="small text-muted d-block">Người phụ trách</label>
                        <span>@Model.TaiKhoan?.HoTen</span>
                    </div>
                    <div class="mt-4 d-grid">
                        <a asp-action="Index" class="btn btn-light rounded-pill border shadow-sm">
                            <i class="fas fa-arrow-left me-1"></i> Quay lại danh sách
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Danh sách phương tiện -->
        <div class="col-lg-8 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-dark text-white py-3">
                    <h5 class="m-0"><i class="fas fa-car me-2"></i>Phương tiện thuê</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4">Phương tiện</th>
                                    <th>Thời gian thuê</th>
                                    <th class="text-end pe-4">Giá thuê</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.ChiTietHopDongs)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="badge bg-dark mb-1">@item.PhuongTien?.BienSo</div>
                                            <div class="small text-muted">@item.PhuongTien?.HangSanXuat - @item.PhuongTien?.LoaiPhuongTien</div>
                                        </td>
                                        <td>
                                            <div class="small">
                                                <i class="fas fa-calendar-alt text-success me-1"></i> Từ: @item.NgayThue.ToString("dd/MM/yyyy")
                                            </div>
                                            <div class="small">
                                                <i class="fas fa-calendar-check text-danger me-1"></i> Đến: @item.NgayTra.ToString("dd/MM/yyyy")
                                            </div>
                                        </td>
                                        <td class="text-end pe-4 fw-bold">@item.GiaThue.ToString("N0") VNĐ</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
