@model DACS.Models.MauHopDong

@{
    ViewData["Title"] = "Tạo Mẫu Hợp Đồng";
}

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Mẫu hợp đồng</a></li>
            <li class="breadcrumb-item active">Tạo mới</li>
        </ol>
    </nav>

    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="m-0"><i class="fas fa-plus-circle me-2"></i> Soạn thảo mẫu hợp đồng</h5>
        </div>
        <div class="card-body p-4">
            <div class="alert alert-info border-0 shadow-sm mb-4">
                <i class="fas fa-info-circle me-2"></i> <strong>Hướng dẫn:</strong> Bạn có thể soạn thảo nội dung hoặc <strong>Copy từ file Word</strong> dán vào đây. 
                Sử dụng các từ khóa sau để hệ thống tự động điền thông tin:
                <div class="mt-2">
                    <span class="badge bg-white text-dark border me-2">[TEN_KHACH_HANG]</span>
                    <span class="badge bg-white text-dark border me-2">[CCCD]</span>
                    <span class="badge bg-white text-dark border me-2">[BIEN_SO]</span>
                    <span class="badge bg-white text-dark border me-2">[NGAY_THUE]</span>
                    <span class="badge bg-white text-dark border me-2">[TONG_TIEN]</span>
                    <span class="badge bg-white text-dark border me-2">[NHAN_VIEN]</span>
                </div>
            </div>

            <form asp-action="Create">
                <div class="row mb-3">
                    <div class="col-md-8">
                        <label asp-for="TenMau" class="form-label fw-bold"></label>
                        <input asp-for="TenMau" class="form-control" placeholder="Ví dụ: Hợp đồng cho thuê xe tự lái v1" />
                        <span asp-validation-for="TenMau" class="text-danger"></span>
                    </div>
                    <div class="col-md-4 d-flex align-items-end">
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" asp-for="LaMacDinh">
                            <label class="form-check-label fw-bold" asp-for="LaMacDinh">Đặt làm mẫu mặc định</label>
                        </div>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="NoiDungHtml" class="form-label fw-bold"></label>
                    <textarea asp-for="NoiDungHtml" id="editor"></textarea>
                    <span asp-validation-for="NoiDungHtml" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-light border px-4 rounded-pill">Quay lại</a>
                    <button type="submit" class="btn btn-primary px-5 rounded-pill shadow">Lưu mẫu hợp đồng</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.ckeditor.com/4.22.1/full/ckeditor.js"></script>
    <script>
        CKEDITOR.replace('editor', {
            height: 500,
            // Thêm các tính năng cần thiết
            toolbar: [
                { name: 'document', items: [ 'Source', '-', 'NewPage', 'Preview', 'Print' ] },
                { name: 'clipboard', items: [ 'cut', 'copy', 'paste', 'pastetext', 'pasteword', '-', 'undo', 'redo' ] },
                { name: 'editing', items: [ 'find', 'replace', '-', 'selectall' ] },
                '/',
                { name: 'basicstyles', items: [ 'Bold', 'Italic', 'Underline', 'Strike', 'Subscript', 'Superscript', '-', 'RemoveFormat' ] },
                { name: 'paragraph', items: [ 'NumberedList', 'BulletedList', '-', 'Outdent', 'Indent', '-', 'Blockquote', 'CreateDiv', '-', 'JustifyLeft', 'JustifyCenter', 'JustifyRight', 'JustifyBlock' ] },
                { name: 'links', items: [ 'Link', 'Unlink', 'Anchor' ] },
                { name: 'insert', items: [ 'Table', 'HorizontalRule', 'SpecialChar', 'PageBreak' ] },
                '/',
                { name: 'styles', items: [ 'Styles', 'Format', 'Font', 'FontSize' ] },
                { name: 'colors', items: [ 'TextColor', 'BGColor' ] },
                { name: 'tools', items: [ 'Maximize', 'ShowBlocks' ] }
            ],
            // Cho phép dán từ Word mượt mà
            pasteFromWordRemoveFontStyles: false,
            pasteFromWordRemoveStyles: false
        });
    </script>
}
